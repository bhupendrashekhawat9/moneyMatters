{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@controller": [
        "./api/controller"
      ],
      "@service": [
        "./api/service"
      ],
      "@types": [
        "./types"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "babel.config.js",
    "nativewind-env.d.ts"
  ]
}
